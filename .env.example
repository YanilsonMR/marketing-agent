# OpenRouter (LLM gateway)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Sender identity
SENDER_NAME=Tu Nombre
SENDER_TITLE=Tu Cargo (ej: Director de Reclutamiento)
COMPANY_NAME=Tu Empresa
COMPANY_DESCRIPTION=Descripcion breve de tu empresa alineada con los servicios de reclutamiento que ofreces.

# Gmail SMTP
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Data
EXCEL_FILE=leads.xlsx

# Behavior
MAX_DAILY_SENDS=50
MAX_VALIDATION_RETRIES=3
SEND_DELAY=2

# Validator limits (Tier 3 AI-generated content)
TIER_3_EMAIL_MIN_WORDS=80
TIER_3_EMAIL_MAX_WORDS=150
SUBJECT_MAX_WORDS=8
